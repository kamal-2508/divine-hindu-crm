# ─────────────────────────────────────────────
# FILE: .env   (in root of project)
# DO NOT commit this file to GitHub
# Copy this file, rename to .env, fill in values
# ─────────────────────────────────────────────

# Supabase — get from supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Twilio WhatsApp — get from twilio.com → Console
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Email (Gmail SMTP)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Manager contact
MANAGER_PHONE=919XXXXXXXXX
MANAGER_EMAIL=manager@divinehinduu.com

# Server
PORT=3000
